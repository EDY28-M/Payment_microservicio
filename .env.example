# SQL Server
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=GestionAcademica;User Id=sa;Password=CHANGE_ME_DB_PASSWORD;TrustServerCertificate=False;

# Stripe
Stripe__SecretKey=REPLACE_WITH_STRIPE_SECRET_KEY
Stripe__PublishableKey=REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
Stripe__WebhookSecret=REPLACE_WITH_STRIPE_WEBHOOK_SECRET

# JWT
JwtSettings__SecretKey=REPLACE_WITH_JWT_SECRET_MIN_32_CHARS
JwtSettings__Issuer=GestionAcademicaAPI
JwtSettings__Audience=GestionAcademicaClients

# URLs
AppSettings__FrontendUrl=https://localhost:3000
AppSettings__BackendPrincipalUrl=https://localhost:5251
